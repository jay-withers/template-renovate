{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Auto-merge policy: non-major dev deps, pins, digests and lockfile maintenance once CI is green. Majors always need a human.",
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge pin and digest updates",
      "matchUpdateTypes": ["pin", "pinDigest", "digest"],
      "automerge": true
    },
    {
      "description": "Auto-merge non-major development dependencies",
      "matchDepTypes": ["devDependencies", "require", "action"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Auto-merge non-major pre-commit hook updates",
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Never auto-merge major updates - always require review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
