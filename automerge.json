{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Auto-merge policy: auto-merge every update once CI is green, including major updates.",
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge all updates once CI passes",
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "bump",
        "rollback",
        "replacement",
        "lockFileMaintenance"
      ],
      "automerge": true
    }
  ]
}
